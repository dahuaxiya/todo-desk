{
  "name": "todo-desk",
  "private": true,
  "version": "0.2.2",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "web:dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "lint": "oxlint",
    "test:ai": "node scripts/test-ai-assistant.mjs",
    "agent:install": "node scripts/install-agent-integration.mjs",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.codex.todo-desk",
    "productName": "Todo Desk",
    "icon": "build/icon",
    "directories": {
      "output": "../../outputs/todo-desk-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
